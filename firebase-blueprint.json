{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores player information, skill level, and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string", "description": "User's full name" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "photoURL": { "type": "string", "format": "uri", "description": "Profile picture URL" },
        "skillLevel": { "type": "number", "description": "Pickleball skill rating (e.g., 2.0 - 5.0)" },
        "location": { "type": "object", "description": "Preferred playing location" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "email"]
    },
    "Match": {
      "title": "Match",
      "description": "Represents a pickleball match or session.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "creatorId": { "type": "string" },
        "courtName": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "players": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["open", "full", "completed", "cancelled"] }
      },
      "required": ["creatorId", "startTime", "status"]
    },
    "GameComment": {
      "title": "Game Comment",
      "description": "Feedback from users on the BentoIQGame.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string", "description": "Optional user ID if logged in" },
        "userName": { "type": "string", "description": "Optional user name if logged in" }
      },
      "required": ["text", "createdAt"]
    },
    "UnsubscribedUser": {
      "title": "Unsubscribed User",
      "description": "Stores emails and phone numbers of users who have unsubscribed.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "unsubscribedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile collection"
    },
    "/matches/{matchId}": {
      "schema": "Match",
      "description": "Pickleball matches collection"
    },
    "/game_comments/{commentId}": {
      "schema": "GameComment",
      "description": "Comments on the game"
    },
    "/unsubscribed_users/{docId}": {
      "schema": "UnsubscribedUser",
      "description": "List of unsubscribed users"
    }
  }
}
